# SQLite database path. Created on first run.
SYS_DYNA_DB_PATH=./data/sys_dyna.db

# Fixed user (stand-in for SSO common auth base)
SYS_DYNA_USER_ID=sample.user
SYS_DYNA_USER_DISPLAY_NAME=Sample User
SYS_DYNA_USER_DEPARTMENT=Analytics

# LLM model identifier surfaced to the UI / persistence layer
SYS_DYNA_MODEL_NAME=gemini-3.1-pro-preview-customtools

# Tool-loop limits (mirrors basic design doc section 5.2)
SYS_DYNA_MAX_TOOL_CALLS=10
SYS_DYNA_PER_TOOL_TIMEOUT_SEC=10
SYS_DYNA_TURN_TIMEOUT_SEC=60
