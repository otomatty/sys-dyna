# sys-dyna v2.0 configuration. Copy to .env and fill in.
# Prefix: SYS_DYNA_

# --- Gemini (Google AI Studio) ---
SYS_DYNA_GEMINI_API_KEY=
SYS_DYNA_GEMINI_MODEL=gemini-3.5-flash
SYS_DYNA_GEMINI_TEMPERATURE=0.2

# --- Supabase (Postgres / Auth / Storage) ---
SYS_DYNA_SUPABASE_URL=
SYS_DYNA_SUPABASE_ANON_KEY=
SYS_DYNA_SUPABASE_SERVICE_ROLE_KEY=
# Postgres connection string used by the LangGraph checkpointer (HITL resume)
SYS_DYNA_CHECKPOINT_DB_URL=

# --- Orchestration limits ---
SYS_DYNA_MAX_TOOL_CALLS=10
SYS_DYNA_PER_TOOL_TIMEOUT_SEC=10
SYS_DYNA_TURN_TIMEOUT_SEC=60
SYS_DYNA_MAX_SCENARIOS=5

# --- Legacy / local dev (v1.0 SQLite path; used until Supabase repo is wired) ---
SYS_DYNA_DB_PATH=./data/sys_dyna.db
SYS_DYNA_MODEL_NAME=gemini-3.5-flash
